{
    "index_patterns": [
        "messages-v1-*"
    ],
    "template": {
        "settings": {
            "index": {
                "sort.field": [
                    "@timestamp"
                ],
                "sort.order": [
                    "desc"
                ]
            },
            "analysis": {
                "filter": {
                    "stop_filter": {
                        "type": "stop",
                        "stopwords": [
                            "_arabic_",
                            "_cjk_",
                            "_english_",
                            "_french_",
                            "_russian_",
                            "_spanish_"
                        ]
                    }
                },
                "analyzer": {
                    "msg_text": {
                        "type": "custom",
                        "tokenizer": "standard",
                        "filter": [
                            "lowercase",
                            "stop_filter"
                        ]
                    }
                }
            }
        },
        "mappings": {
            "_routing": {
                "required": true
            },
            "properties": {
                "@timestamp": {
                    "type": "date"
                },
                "org_id": {
                    "type": "integer"
                },
                "contact_uuid": {
                    "type": "keyword"
                },
                "text": {
                    "type": "text",
                    "analyzer": "msg_text"
                },
                "in_ticket": {
                    "type": "boolean"
                }
            }
        }
    }
}